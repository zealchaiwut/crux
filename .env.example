# Neon Postgres connection string
# Obtain from neon.tech → your project → Connection Details → copy the connection string
# Format: postgresql://user:password@ep-xxxx-xxxx.region.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.region.neon.tech/neondb?sslmode=require

# Application settings
PORT=8000
ENV=development

# Auth — required, must be at least 16 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=changeme_generate_a_real_secret_before_deploy

# Anthropic API key — OPTIONAL. By default crux calls Claude via the `claude` CLI
# (subscription, no key). Only needed if you switch the provider to "Anthropic API"
# in the in-app Settings modal, where usage is capped by a USD budget.
# ANTHROPIC_API_KEY=sk-ant-...
